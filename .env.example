# Copy this file to .env and fill in the values for your setup.
#   cp .env.example .env
# .env is gitignored, so your keys stay out of version control.

# ── LLM for answer generation (the "generate" step in RAG Q&A) ──
# Retrieval, chunking, eval, and embeddings all work WITHOUT this —
# it only powers the final generated answer in the RAG Q&A tab / CLI.

# --- Option A: OpenAI (default) ---
# Leave OPENAI_BASE_URL and LLM_MODEL unset to use api.openai.com with gpt-4o.
OPENAI_API_KEY=sk-your-openai-key-here

# --- Option B: Local model via Ollama ---
# Ollama exposes an OpenAI-compatible API, so no code changes are needed —
# just uncomment these three and comment out the OpenAI key above.
# Requires: `ollama pull llama3.1` (and the Ollama app running).
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama          # any non-empty string; Ollama ignores it
# LLM_MODEL=gemma3n:e4b

# OPENAI_BASE_URL  — API endpoint. Unset = real OpenAI. Set for Ollama / other OpenAI-compatible servers.
# OPENAI_API_KEY   — your key (or any non-empty string for Ollama).
# LLM_MODEL        — model name. Unset defaults to "gpt-4o".
